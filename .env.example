# Upstash Redis — these are auto-injected when you install the Upstash Redis
# integration from the Vercel Marketplace. For local dev, leave them blank and
# the app will fall back to in-memory + localStorage (single-device only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legacy Vercel KV names are also accepted, for projects migrated from the
# old Vercel KV integration.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
