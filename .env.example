# Vercel Redis (native) — auto-injected when you attach a Redis database
# to the project in the Vercel dashboard (Storage → Connect Project).
#
# For LOCAL development, copy this file to `.env.local` (which is gitignored)
# and paste the real URL there. NEVER put real credentials in this file.
#
# Without a Redis URL the app still runs, but scores stay in the current
# browser's localStorage only — no cross-device sync.
REDIS_URL=

# Legacy fallback names — also accepted if present:
# KV_URL=
